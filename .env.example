# ── LLM Provider ──────────────────────────────────────────────────────
# 選擇 provider: ollama | grok | openai
LLM_PROVIDER=ollama

# Ollama（本機，預設）
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:12b         # 推薦: gemma3:12b | gemma3:27b | gemma2:9b

# xAI Grok（雲端）
# LLM_PROVIDER=grok
# LLM_MODEL=grok-beta          # 或 grok-2
# GROK_API_KEY=xai-...

# OpenAI（fallback）
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── Embedding ──────────────────────────────────────────────────────────
# 預設跟隨 LLM_PROVIDER（ollama → nomic-embed-text, openai → text-embedding-3-large）
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text   # 768 dim；換模型時須同步更新 EMBEDDING_DIM
# EMBEDDING_DIM=768              # 留空則自動推斷；換模型前先刪除舊 Milvus collection

# Vector Database (Milvus)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=yiguandao_kb

# Relational Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://yiguandao:secret@localhost:5436/yiguandao_kb

# Sessions
MAX_MESSAGES_PER_SESSION=100

# Admin seed（首次啟動自動建立管理員帳號）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Security
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# App
APP_ENV=development          # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
