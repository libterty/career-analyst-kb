# ── LLM Provider ──────────────────────────────────────────────────────
# 選擇 provider: ollama | grok | openai
LLM_PROVIDER=ollama

# Ollama（本機，預設）
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:12b         # 推薦: gemma3:12b | gemma3:27b | gemma2:9b

# xAI Grok（雲端）
# LLM_PROVIDER=grok
# LLM_MODEL=grok-beta
# GROK_API_KEY=xai-...

# OpenAI（fallback）
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── Embedding ──────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text   # 768 dim
# EMBEDDING_DIM=768

# ── Vector Database (Milvus) ───────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=career_kb

# ── Relational Database (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://career:secret@localhost:5436/career_kb

# ── Sessions ──────────────────────────────────────────────────────────
MAX_MESSAGES_PER_SESSION=100

# ── Admin Seed ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ── Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── App ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── YouTube Ingestion ─────────────────────────────────────────────────
YOUTUBE_API_KEY=                   # YouTube Data API v3 Key
WHISPER_MODEL=large-v3             # base | small | medium | large-v3
