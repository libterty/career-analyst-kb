### --- 專案特定資料 (Data & Docs) --- ###
# 原始文件與處理後的資料通常很大，且包含敏感資訊，不建議進 Git
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# 如果你有本地的向量數據庫持久化檔案 (若 Docker 掛載到本地)
# milvus_data/
# volumes/

### --- 環境變數與密鑰 (極度重要) --- ###
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 排除所有可能包含 API Key 的檔案
*.pem
*.key
*.secret

### --- 規劃文件 --- ###
.planning/*

### --- 編輯器與系統相關 --- ###
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.log

### --- 測試與分析 --- ###
.target/
.pytest_cache/
.coverage
htmlcov/
nosetests.xml
coverage.xml
*.cover
.results/
e2e/

# 忽略 data 資料夾下所有內容
data/raw/*
data/processed/*
data/subtitles/*
!data/subtitles/.gitkeep
data/embeddings/*


!data/processed/.gitkeep
!data/raw/.gitkeep
!data/embeddings/.gitkeep

tmp/*

# 忽略monorepo中其他服務的編譯輸出和依賴
services/voltagent-career/dist/*
services/voltagent-career/node_modules/*

# 忽略claude相關的資料夾和檔案
.claude/*

# 忽略eval result
eval/results/*